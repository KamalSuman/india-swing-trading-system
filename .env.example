INDIA_SWING_HISTORICAL_PRICES_ROOT=var/historical_prices
INDIA_SWING_IDENTITY_REGISTRY_ROOT=var/identity_registry
INDIA_SWING_DAILY_PIPELINE_ROOT=var/daily_pipeline
